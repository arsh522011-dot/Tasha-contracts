rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net - deny by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Projects collection
    match /projects/{projectId} {
      allow read, write: if true;
    }

    // Services collection
    match /services/{serviceId} {
      allow read, write: if true;
    }

    // Testimonials collection
    match /testimonials/{testimonialId} {
      allow read, write: if true;
    }

    // Team collection
    match /team/{memberId} {
      allow read, write: if true;
    }

    // Industries We Served collection
    match /industries/{industryId} {
      allow read, write: if true;
    }

    // Certs collection
    match /certs/{certId} {
      allow read, write: if true;
    }

    // Careers listings collection
    match /careers/{careerId} {
      allow read, write: if true;
    }

    // Quote Requests submissions
    match /quotes/{quoteId} {
      allow read, write: if true;
    }

    // Contact form submissions
    match /contacts/{contactId} {
      allow read, write: if true;
    }

    // Career applications submittals
    match /applications/{appId} {
      allow read, write: if true;
    }

    // System config document
    match /system/{sysId} {
      allow read, write: if true;
    }

    // Partners collection
    match /partners/{partnerId} {
      allow read, write: if true;
    }
  }
}
