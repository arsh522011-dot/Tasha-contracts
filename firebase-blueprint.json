      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "location": { "type": "string" },
        "date": { "type": "string" },
